      "update_interval": "48h0m0s"
    }
  ],

  // ==========================================================
  // route.final: 路由兜底出站
  // ==========================================================
  /*
   * final: "Final"
   * 所有 route.rules 未匹配的流量，走 tag 为 "Final" 的出站。
   *
   * "Final" 是一个 selector 类型的出站，
   * 默认选择 "PROXY"。
   * 因此未匹配流量默认走代理。
   *
   * 这是"白名单"安全策略：
   * - 明确指定哪些走直连（国内规则集）
   * - 其他全部走代理
   *
   * 对比"黑名单"策略：
   * - 明确指定哪些走代理（GFW 列表）
   * - 其他全部直连
   *
   * 白名单策略更安全（不会漏代理被封网站），
   * 但代理服务器负担更重。
   */
  "final": "Final",

  // ==========================================================
  // route.auto_detect_interface: 自动检测出口网卡
  // ==========================================================
  /*
   * auto_detect_interface: true
   *
   * 自动选择网络出口接口。
   *
   * 场景：
   * - 设备有多个网卡（WiFi + 有线 + VPN）
   * - sing-box 需要知道从哪个网卡发出直连流量
   * - 启用后自动检测当前活跃的主网卡
   *
   * 大多数情况下保持 true 即可。
   * 特殊场景（如双网卡负载均衡、指定出口网卡）
   * 可能需要手动设置。
   */
  "auto_detect_interface": true,

  // ==========================================================
  // route.default_domain_resolver: 默认域名解析器
  // ==========================================================
  /*
   * default_domain_resolver: "alidns-quic"
   *
   * 路由模块的默认 DNS 服务器。
   *
   * 当出站需要解析目标域名时（且出站未指定自己的
   * domain_resolver），使用此 DNS 服务器。
   *
   * 选择 alidns-quic 的原因：
   * - 阿里 DNS 对国内外域名都有较好覆盖
   * - QUIC 协议延迟低
   * - 作为默认值适用于大多数场景
   *
   * 注意：
   * 这与 dns 模块的 final: "adguard-dns" 是不同的概念：
   * - dns.final：客户端 DNS 查询的兜底 DNS 服务器
   * - route.default_domain_resolver：出站连接时解析目标域名用
   */
  "default_domain_resolver": "alidns-quic"
},

/*
 * ============================================================
 * experimental 模块：实验性功能
 * 包含缓存、Clash API 兼容、调试等
 * ============================================================
 */
"experimental": {

  // ==========================================================
  // cache_file: 持久化缓存
  // ==========================================================
  "cache_file": {
    /*
     * enabled: true
     * 启用持久化缓存。
     *
     * 将 fakeip 映射、DNS 缓存、规则集等数据
     * 保存到磁盘文件中。
     *
     * 好处：
     * 1. sing-box 重启后无需重新下载规则集
     * 2. fakeip ↔ domain 映射不丢失
     * 3. DNS 缓存持久化，重启后仍有缓存
     * 4. 启动速度大幅加快
     */
    "enabled": true,

    /*
     * path: "cache.db"
     * 缓存文件路径。
     *
     * 相对路径，存放在 sing-box 工作目录下。
     * 格式通常为 BoltDB 或 BadgerDB。
     *
     * 注意：
     * - 长期运行后，cache.db 可能变得很大（数百 MB）
     * - 如果怀疑缓存数据有问题，可以删除此文件，
     *   sing-box 会自动重建
     * - 建议定期清理（如每月删除一次）
     */
    "path": "cache.db",

    /*
     * cache_id: "cinchov"
     * 缓存标识符。
     *
     * 用于区分不同配置文件的缓存。
     * 如果运行多个 sing-box 实例，
     * 应使用不同的 cache_id 避免冲突。
     *
     * "cinchov" 看起来像自定义字符串，
     * 可能是作者的用户名或项目代号。
     *
     * 如果修改了配置文件（如更换了规则集 URL），
     * 更改 cache_id 会强制清空旧缓存。
     */
    "cache_id": "cinchov",

    /*
     * store_fakeip: true
     * 持久化 fakeip 到域名的映射关系。
     *
     * 重启后：
     * - fakeip 198.18.5.123 仍然对应 google.com
     * - 已建立的连接不会因为重启而"忘记"映射
     */
    "store_fakeip": true,

    /*
     * store_dns: true
     * 持久化 DNS 查询缓存。
     *
     * 重启后：
     * - 之前解析过的域名仍保留在缓存中
     * - 无需重新发起 DNS 查询
     * - 加速启动后的首次访问
     *
     * 注意：
     * DNS 缓存有 TTL，过期的记录不会保存。
     * 但如果使用了 rewrite_ttl 或 optimistic，
     * 过期记录可能仍然保留。
     */
    "store_dns": true
  },

  // ==========================================================
  // clash_api: Clash API 兼容
  // ==========================================================
  "clash_api": {
    /*
     * external_controller: "127.0.0.1:9090"
     * HTTP API 监听地址。
     *
     * 提供与 Clash 兼容的 REST API，
     * 可用于：
     * 1. Web 管理面板（yacd、MetaCubeX、Razord）
     * 2. 命令行切换节点
     * 3. 第三方工具集成
     *
     * 127.0.0.1 仅本地访问，安全。
     * 端口 9090 是 Clash API 的默认端口。
     *
     * 常用 API 端点：
     * - GET /proxies         查看所有代理节点
     * - PUT /proxies/PROXY   切换 PROXY 选择器的节点
     * - GET /traffic         查看流量统计
     * - GET /connections     查看当前连接
     *
     * 安全提醒：
     * 不要暴露到公网（0.0.0.0）！
     * API 没有身份验证，任何人可以切换你的节点。
     * 如果必须远程访问，使用 SSH 隧道或反向代理 + 认证。
     */
    "external_controller": "127.0.0.1:9090",

    /*
     * external_ui: "ui"
     * Web 面板静态文件路径。
     *
     * 相对于 sing-box 工作目录的 ui 文件夹。
     * 通常放置 yacd 或 MetaCubeX 的编译产物。
     *
     * 访问方式：
     * 浏览器打开 http://127.0.0.1:9090/ui/
     *
     * 文件结构示例：
     * sing-box 工作目录/
     * ├── config.json
     * ├── cache.db
     * └── ui/
     *     ├── index.html
     *     ├── css/
     *     └── js/
     *
     * 如果此文件夹为空或不存在，
     * API 仍然可工作，只是没有可视化界面。
     */
    "external_ui": "ui",

    /*
     * default_mode: "rule"
     * 启动时的默认代理模式。
     *
     * 可选值：
     * - "rule"：按规则分流（正常模式）
     * - "global"：全局代理
     * - "direct"：全局直连
     *
     * 与 route.rules 中的 clash_mode 配合使用。
     * 用户通过 API/WebUI 切换模式时，
     * clash_mode 匹配的规则生效。
     */
    "default_mode": "rule"
  },

  // ==========================================================
  // debug: 调试与性能调优
  // ==========================================================
  "debug": {
    /*
     * gc_percent: 100
     * Go 垃圾回收 (GC) 百分比。
     *
     * 含义：当堆内存增长超过上次 GC 后的 100% 时触发 GC。
     * 默认值：100。
     *
     * 调低（如 20）：GC 更频繁，内存占用更低，但 CPU 占用更高
     * 调高（如 200）：GC 更少，吞吐更高，但内存占用更大
     *
     * 100 是 Go 的默认值，适用于大多数场景。
     * 如果 sing-box 运行在内存受限设备（如 256MB 路由器），
     * 可降到 50 或更低。
     */
    "gc_percent": 100,

    /*
     * memory_limit: "400MB"
     * 软内存限制。
     *
     * Go 1.19+ 引入了软内存限制功能。
     * 设置后，Go 运行时会尽量将内存使用控制在此限制以下。
     *
     * 400MB 对于代理工具来说是一个合理的值：
     * - 规则集加载：~50MB
     * - DNS 缓存（256000 条）：~100MB
     * - fakeip 映射表：~20-50MB
     * - 连接缓冲：~50-100MB
     * - 总计合理值：200-400MB
     *
     * 如果内存超过 400MB，Go 会积极触发 GC。
     *
     * 注意：
     * 这是"软"限制，Go 会尽力但不保证绝对不超出。
     * 极端情况下（如百万级并发连接），内存仍可能超出。
     *
     * 设备配置建议：
     * - 路由器 128MB：memory_limit: "64MB"（可能不够）
     * - 路由器 512MB：memory_limit: "256MB"
     * - PC/NAS 4GB+：memory_limit: "400MB" 或更高
     * - 服务器 16GB+：memory_limit: "2GB"
     */
    "memory_limit": "400MB"
  }
}

/*
 * ============================================================
 * 全局配置总结 & 核心问题
 * ============================================================
 *
 * 1. 规则集数量：43 个远程规则集
 *    每个 48h 更新一次，全部通过代理下载。
 *    这是相当庞大的规则集集合。
 *
 * 2. 严重的标签冗余：
 *    a) Google 相关：geosite-google, google-cn, Google (3个)
 *    b) YouTube：geosite-youtube, youtube (2个)
 *    c) Apple：apple, Apple, apple-cn (3个)
 *    d) 广告：geosite-category-ads-all, geosite_adguard, Ads (3个)
 *    e) Telegram：telegram, telegramip, telegram_ip (3个)
 *    f) 代理：proxy, Proxy, gfw (3个，高度重叠)
 *
 * 3. 远程 URL 混合使用：
 *    - jsDelivr CDN：国内下载速度较好
 *    - raw.githubusercontent.com：依赖于代理
 *    - 部分规则集使用 release 下载链接
 *    - 下载成功率依赖于代理稳定性
 *
 * 4. 启动行为：
 *    首次启动需要下载 43 个规则集文件，
 *    如果有 cache.db，后续启动从缓存加载（秒开）；
 *    如果没有缓存，可能需要数分钟才能完全加载。
 *
 * 5. 优化建议：
 *    - 合并重复标签，从 ~43 个减少到 ~25 个
 *    - 统一规则集来源（全用 jsDelivr 或全用 GitHub）
 *    - 将不常用的规则集删除（如多余的游戏/流媒体分类）
 *    - 考虑使用本地规则集替代部分远程规则集
 *      以减少下载依赖
 *
 * 6. 配置文件总体评估：
 *    这是一个功能极其全面的"全家桶"配置，
 *    几乎覆盖了所有常见的使用场景。
 *    但代价是配置极其冗长、大量重复、
 *    维护成本高。
 *
 *    适合：希望"开箱即用"覆盖所有情况的高级用户
 *    不适合：追求简洁、低内存占用的场景
 */
