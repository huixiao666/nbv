      "http_client": "default",
      "update_interval": "48h0m0s"
    },
    {
      /*
       * tag: "httpDNS"
       * 阻止 HTTP DNS 的规则集
       *
       * 这些域名通常被用于：
       * - 通过 HTTP 协议进行 DNS 查询（绕过系统 DNS）
       * - DNS 隧道（数据泄露通道）
       *
       * 阻止它们可以强制应用使用系统 DNS
       * （经过 sing-box 的 DNS 模块处理）。
       */
      "type": "remote",
      "tag": "httpDNS",
      "url": "https://raw.githubusercontent.com/senshinya/singbox_ruleset/main/rule/BlockHttpDNS/BlockHttpDNS.srs",
      "http_client": "default",
      "update_interval": "48h0m0s"
