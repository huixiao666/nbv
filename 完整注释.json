       *
       * 包含：Netflix、Disney+、HBO、Hulu、
       *       Spotify、YouTube Music 等
       *
       * 注意：此规则集中已包含 youtube，
       * 而配置中还有单独的 youtube 和 geosite-youtube。
       * 多重覆盖。
       */
      "type": "remote",
      "tag": "GlobalMedia",
      "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/category-entertainment.srs",
